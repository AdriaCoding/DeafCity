[{"start":738,"end":4217,"text":"I went to school"},{"start":4408,"end":8294,"text":"accompanied by a friend and her father."},{"start":8460,"end":11709,"text":"We went in the car"},{"start":11898,"end":15878,"text":"and when I got out, my friend closed the door."},{"start":16108,"end":18068,"text":"And his dad: What's up?"},{"start":18274,"end":20000,"text":"My finger!"},{"start":20100,"end":22249,"text":"And I pointed my finger at him..."},{"start":22366,"end":25199,"text":"And everyone: what's up?"},{"start":25314,"end":27652,"text":"So they started laughing."},{"start":27859,"end":29511,"text":"I crushed my finger with the car door!"},{"start":29671,"end":31635,"text":"And it hurt a lot!"}]
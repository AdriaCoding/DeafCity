[{"start":738,"end":4217,"text":"Fui a la escuela"},{"start":4408,"end":8294,"text":"acompa\u00f1ado de una amiga y de su pap\u00e1."},{"start":8460,"end":11709,"text":"Fuimos en el auto"},{"start":11898,"end":15878,"text":"y cuando baj\u00e9, mi amiga cerr\u00f3 la puerta."},{"start":16108,"end":18068,"text":"Y su pap\u00e1: \u00bfQu\u00e9 pasa?"},{"start":18274,"end":20000,"text":"\u00a1Mi dedo!"},{"start":20100,"end":22249,"text":"Y yo le se\u00f1alaba mi dedo..."},{"start":22366,"end":25199,"text":"Y todos: \u00bfqu\u00e9 pasa?"},{"start":25314,"end":27652,"text":"As\u00ed comenzaron a re\u00edr."},{"start":27859,"end":29511,"text":"\u00a1Me machucaron el dedo!"},{"start":29671,"end":31635,"text":"!Y me dol\u00eda much\u00edsimo!"}]
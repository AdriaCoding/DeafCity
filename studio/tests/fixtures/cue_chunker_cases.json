[
  {
    "name": "single_short_utterance_is_one_cue",
    "words": [
      { "start": 0.0, "end": 0.5, "text": "Hola" },
      { "start": 0.6, "end": 1.0, "text": "món" }
    ],
    "expected": [
      { "start": 0.0, "end": 1.0, "text": "Hola món" }
    ]
  },
  {
    "name": "exceeding_hard_char_cap_splits_at_word_boundary",
    "params": { "cps_target": 9999, "min_duration": 0 },
    "words": [
      { "start": 0.00, "end": 0.40, "text": "paraula" },
      { "start": 0.45, "end": 0.85, "text": "paraula" },
      { "start": 0.90, "end": 1.30, "text": "paraula" },
      { "start": 1.35, "end": 1.75, "text": "paraula" },
      { "start": 1.80, "end": 2.20, "text": "paraula" },
      { "start": 2.25, "end": 2.65, "text": "paraula" },
      { "start": 2.70, "end": 3.10, "text": "paraula" },
      { "start": 3.15, "end": 3.55, "text": "paraula" }
    ],
    "expected": [
      { "start": 0.00, "end": 2.65, "text": "paraula paraula paraula paraula paraula paraula" },
      { "start": 2.70, "end": 3.55, "text": "paraula paraula" }
    ]
  },
  {
    "name": "pause_over_threshold_breaks_under_char_cap",
    "params": { "cps_target": 9999, "min_duration": 0 },
    "words": [
      { "start": 0.00, "end": 0.40, "text": "Hola" },
      { "start": 0.50, "end": 0.90, "text": "món" },
      { "start": 2.00, "end": 2.40, "text": "Adéu" },
      { "start": 2.50, "end": 2.90, "text": "amics" }
    ],
    "expected": [
      { "start": 0.00, "end": 0.90, "text": "Hola món" },
      { "start": 2.00, "end": 2.90, "text": "Adéu amics" }
    ]
  },
  {
    "name": "capacity_break_retreats_to_strong_punctuation",
    "params": { "cps_target": 9999, "min_duration": 0 },
    "words": [
      { "start": 0.00, "end": 0.30, "text": "Vaig" },
      { "start": 0.40, "end": 0.70, "text": "anar" },
      { "start": 0.80, "end": 1.10, "text": "a" },
      { "start": 1.20, "end": 1.50, "text": "casa." },
      { "start": 1.60, "end": 1.90, "text": "Després" },
      { "start": 2.00, "end": 2.30, "text": "vam" },
      { "start": 2.40, "end": 2.70, "text": "menjar" },
      { "start": 2.80, "end": 3.10, "text": "una" },
      { "start": 3.20, "end": 3.50, "text": "amanida" },
      { "start": 3.60, "end": 3.90, "text": "fresca" }
    ],
    "expected": [
      { "start": 0.00, "end": 1.50, "text": "Vaig anar a casa." },
      { "start": 1.60, "end": 3.90, "text": "Després vam menjar una amanida fresca" }
    ]
  },
  {
    "name": "max_duration_backstop_splits_low_char_stream",
    "params": { "cps_target": 9999, "min_duration": 0 },
    "words": [
      { "start": 0.00, "end": 1.00, "text": "la" },
      { "start": 1.20, "end": 2.20, "text": "la" },
      { "start": 2.40, "end": 3.40, "text": "la" },
      { "start": 3.60, "end": 4.60, "text": "la" },
      { "start": 4.80, "end": 5.80, "text": "la" },
      { "start": 6.00, "end": 7.00, "text": "la" }
    ],
    "expected": [
      { "start": 0.00, "end": 5.80, "text": "la la la la la" },
      { "start": 6.00, "end": 7.00, "text": "la" }
    ]
  }
]
